# ─────────────────────────────────────────────────────────────────────────────
# ShieldScan AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# Required: Get free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Cloud Project ID (for Vertex AI Search / Cloud Run)
GCP_PROJECT_ID=your-gcp-project-id

# Optional: For full RAG integration with Vertex AI Search
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_SEARCH_ENGINE_ID=your-vertex-search-engine-id
